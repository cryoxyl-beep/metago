# VITE_GEMINI_API_KEY: Required for Gemini-based clean reconstructions.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# VITE_GROQ_API_KEY: Required for Qwen-2.5-Coder-32B structural recovery on Groq.
# Users configure this via the Secrets panel in the AI Studio UI with VITE_ prefix.
VITE_GROQ_API_KEY="YOUR_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
